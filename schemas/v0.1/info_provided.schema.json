{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Loop Information Provided (info_provided) v0.1",
  "type": "object",
  "allOf": [
    {
      "$ref": "common.schema.json#/$defs/Envelope"
    }
  ],
  "properties": {
    "message_type": {
      "const": "info_provided"
    },
    "message_action": {
      "const": "info_provided"
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in_reply_to_request",
        "answers"
      ],
      "properties": {
        "in_reply_to_request": {
          "$ref": "common.schema.json#/$defs/Uuid"
        },
        "answers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "answer_text": {
                "type": "string"
              },
              "structured": {
                "description": "Optional machine-parseable answer matching the targeted field_path's expected shape."
              },
              "attachment_ref": {
                "type": "string"
              }
            },
            "anyOf": [
              {
                "required": [
                  "answer_text"
                ]
              },
              {
                "required": [
                  "structured"
                ]
              },
              {
                "required": [
                  "attachment_ref"
                ]
              }
            ]
          }
        }
      }
    }
  }
}
