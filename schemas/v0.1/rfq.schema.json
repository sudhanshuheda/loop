{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Loop Request for Quote (rfq) v0.1",
  "type": "object",
  "allOf": [
    {
      "$ref": "common.schema.json#/$defs/Envelope"
    }
  ],
  "properties": {
    "message_type": {
      "const": "rfq"
    },
    "message_action": {
      "enum": [
        "rfq_initial",
        "rfq_modification",
        "rfq_addition"
      ]
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "quote_deadline",
        "line_items"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "quote_deadline": {
          "$ref": "common.schema.json#/$defs/RFC3339DateTime"
        },
        "validity_required": {
          "$ref": "common.schema.json#/$defs/ISODuration"
        },
        "currency_preference": {
          "$ref": "common.schema.json#/$defs/CurrencyCode"
        },
        "line_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "common.schema.json#/$defs/LineItemUnpriced"
          }
        },
        "end_customer": {
          "$ref": "common.schema.json#/$defs/Party"
        },
        "flags": {
          "$ref": "common.schema.json#/$defs/OperationalFlags"
        },
        "terms": {
          "$ref": "common.schema.json#/$defs/Terms"
        },
        "extensions": {
          "type": "object"
        }
      }
    }
  }
}
