{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Loop Purchase Order (po) v0.1",
  "type": "object",
  "allOf": [
    {
      "$ref": "common.schema.json#/$defs/Envelope"
    }
  ],
  "properties": {
    "message_type": {
      "const": "po"
    },
    "message_action": {
      "enum": [
        "award",
        "other"
      ]
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "po_number",
        "line_items",
        "subtotal",
        "total",
        "delivery"
      ],
      "properties": {
        "po_number": {
          "type": "string",
          "minLength": 1
        },
        "quote_message_id": {
          "$ref": "common.schema.json#/$defs/Uuid"
        },
        "line_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "common.schema.json#/$defs/LineItemPriced"
          }
        },
        "subtotal": {
          "$ref": "common.schema.json#/$defs/Money"
        },
        "charges": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/LabeledMoney"
          }
        },
        "taxes": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/LabeledMoney"
          }
        },
        "total": {
          "$ref": "common.schema.json#/$defs/Money"
        },
        "delivery": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ship_to"
          ],
          "properties": {
            "ship_to": {
              "$ref": "common.schema.json#/$defs/Address"
            },
            "bill_to": {
              "$ref": "common.schema.json#/$defs/Address"
            },
            "required_by": {
              "$ref": "common.schema.json#/$defs/ISODate"
            }
          }
        },
        "terms": {
          "$ref": "common.schema.json#/$defs/Terms"
        },
        "notes": {
          "type": "string"
        },
        "extensions": {
          "type": "object"
        }
      }
    }
  }
}
